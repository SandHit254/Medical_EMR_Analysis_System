# =================================================================
# 1. 开发环境与编译器 (Conda & Python)
# =================================================================
# 忽略整个 Conda 环境目录
.conda/
env/
venv/
ENV/

# 忽略 Python 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# =================================================================
# 2. 深度学习模型与权重 (Models)
# =================================================================
# 严禁上传几百 MB 的模型文件
models/*.pt
models/*.pth
models/*.bin
models/*.onnx
models/*.ckpt

# =================================================================
# 3. 数据集与输出记录 (Data & Output)
# =================================================================
# 忽略数据集内容（包含你的 data 文件夹）
data/
!data/.gitkeep

# 忽略系统生成的病例快照存档
output/
records/
!output/.gitkeep

# =================================================================
# 4. 操作系统与编辑器 (System & IDE)
# =================================================================
.DS_Store
.vscode/
.idea/
*.swp
*.log

# 忽略根目录下的零散内容
test.jpg
test2.jpg
uploads_temp
ToDoList.md
1.txt
paper
paper/*
out/tmp/tmp.png
.gitignore
tmp.puml
docs/ref
